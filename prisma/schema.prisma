generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employer {
  id                       String             @id @default(uuid())
  name                     String
  email                    String             @unique
  password                 String
  companyName              String
  phone                    String
  country                  String?
  city                     String?
  isSuspended              Boolean            @default(false)
  isVerified               Boolean            @default(false)
  subscriptionStatus       SubscriptionStatus @default(TRIAL)
  subscriptionStartDate    DateTime?
  subscriptionEndDate      DateTime?
  paystackCustomerCode     String?
  paystackSubscriptionCode String?
  stripeCustomerId         String?
  stripeSubscriptionId     String?
  billingPeriod            String?  // "monthly" | "yearly"
  paymentProvider          String?  // "paystack" | "stripe"
  mattermostTeamId         String?

  // Consent & compliance (GDPR / NDPR / POPIA)
  termsAcceptedAt          DateTime?
  privacyAcceptedAt        DateTime?
  marketingConsent         Boolean   @default(false)
  consentIp                String?

  // Password reset
  passwordResetToken       String?
  passwordResetExpiry      DateTime?

  // Relations
  jobs                     Job[]
  applications             Application[]
  interviews               Interview[]
  offers                   Offer[]
  messagesSent             Message[]          @relation("EmployerMessagesSent")
  messagesReceived         Message[]          @relation("EmployerMessagesReceived")
  testResults              TestResult[]
  customTests              AptitudeTest[]     @relation("EmployerTests")
  mattermostChannels       MattermostChannel[]
  notificationLogs         NotificationLog[]  // Generic notification logs for this employer
  notificationPreferences  EmployerNotificationPreference?
  employmentRecords        EmploymentRecord[]
  companyVerification      CompanyVerification?

  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
}

model EmployerNotificationPreference {
  id                 String   @id @default(uuid())
  employerId         String   @unique
  employer           Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  email              Boolean  @default(true)
  push               Boolean  @default(true)
  mattermost         Boolean  @default(true)
  interviewReminders Boolean  @default(true)
  applicationUpdates Boolean  @default(true)
}

model MattermostChannel {
  id          String   @id @default(uuid())
  employerId  String
  employer    Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  channelId   String
  channelName String
}

model Candidate {
  id                         String    @id @default(uuid())
  name                       String
  email                      String    @unique
  password                   String
  phone                      String
  country                    String?
  city                       String?
  isSuspended                Boolean   @default(false)
  expertise                  String    // e.g., Finance, IT, Marketing
  skills                     String[]  // Max 5 skills handled in app logic or Prisma
  personalStatement          String?   @db.Text
  
  isVerified                 Boolean   @default(false)

  onboardingTestPassed       Boolean   @default(false)
  onboardingTestScore        Float?
  highestQualification       String?
  university                 String?
  degree                     String?
  professionalQualifications String?
  hobbies                    String?
  mattermostUserId           String?
  paystackRecipientCode      String?   // for salary disbursement via Paystack Transfer

  // Consent & compliance (GDPR / NDPR / POPIA)
  termsAcceptedAt            DateTime?
  privacyAcceptedAt          DateTime?
  marketingConsent           Boolean   @default(false)
  consentIp                  String?

  // Password reset
  passwordResetToken         String?
  passwordResetExpiry        DateTime?

  // Relations
  workHistory                WorkHistory[]
  references                 Reference[]
  applications               Application[]
  interviews                 Interview[]
  offers                     Offer[]
  testResults                TestResult[]
  assignedTests              AptitudeTest[]     @relation("CandidateAssignedTests")
  messagesSent               Message[]          @relation("CandidateMessagesSent")
  messagesReceived           Message[]          @relation("CandidateMessagesReceived")
  notificationLogs           NotificationLog[]
  notificationPreferences    CandidateNotificationPreference?
  pushSubscriptions          PushSubscription[]
  employmentRecords          EmploymentRecord[]
  payslips                   Payslip[]
  programmeEnrolments        ProgrammeMember[]
  identityVerification       IdentityVerification?

  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
}

model PushSubscription {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  endpoint    String    @unique
  p256dh      String
  auth        String
  createdAt   DateTime  @default(now())
}

model CandidateNotificationPreference {
  id                 String   @id @default(uuid())
  candidateId        String   @unique
  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  email              Boolean  @default(true)
  push               Boolean  @default(true)
  mattermost         Boolean  @default(false)
  interviewReminders Boolean  @default(true)
  jobAlerts          Boolean  @default(true)
  applicationUpdates Boolean  @default(true)
}

model WorkHistory {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String    @db.Text
}

model Reference {
  id           String    @id @default(uuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name         String
  email        String
  phone        String
  relationship String
}

model Job {
  id          String     @id @default(uuid())
  employerId  String
  employer    Employer   @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title       String
  description String?    @db.Text
  location    String?
  type        String?
  status      JobStatus  @default(ACTIVE)

  // Location (granular)
  country     String?
  city        String?

  // Salary embedded structure (optional range with currency)
  salaryMin   Float?
  salaryMax   Float?
  currency    String?
  salaryRate  String?   // "hourly" | "daily" | "weekly" | "monthly" | "annual"

  // Posting lifecycle
  expiresAt   DateTime?

  // Relations
  applications        Application[]
  interviews          Interview[]
  offers              Offer[]
  mattermostChannels  MattermostChannel[]
  programmeJobs       ProgrammeJob[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Application {
  id           String            @id @default(uuid())
  jobId        String
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId  String
  candidate    Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  employerId   String
  employer     Employer          @relation(fields: [employerId], references: [id], onDelete: Cascade)
  status       ApplicationStatus @default(APPLIED)
  
  resumeUrl    String?
  coverLetter  String?           @db.Text

  // Relations (1-to-1 matching to Application)
  testResultId String?           @unique
  testResult   TestResult?       @relation(fields: [testResultId], references: [id])
  interviewId  String?           @unique
  interview    Interview?        @relation(fields: [interviewId], references: [id])
  offerId      String?           @unique
  offer        Offer?            @relation(fields: [offerId], references: [id])
  
  postHireLogs PostHireLog[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([jobId, candidateId]) // A candidate can only apply once per job
}

model Message {
  id                String      @id @default(uuid())
  content           String      @db.Text
  isRead            Boolean     @default(false)
  deletedBySender   Boolean     @default(false)
  deletedByReceiver Boolean     @default(false)

  // Polymorphic-like relationships explicitly modeled
  senderType        UserType
  senderEmployerId  String?
  senderEmployer    Employer?   @relation("EmployerMessagesSent", fields: [senderEmployerId], references: [id])
  senderCandidateId String?
  senderCandidate   Candidate?  @relation("CandidateMessagesSent", fields: [senderCandidateId], references: [id])

  receiverEmployerId  String?
  receiverEmployer    Employer?   @relation("EmployerMessagesReceived", fields: [receiverEmployerId], references: [id])
  receiverCandidateId String?
  receiverCandidate   Candidate?  @relation("CandidateMessagesReceived", fields: [receiverCandidateId], references: [id])
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Interview {
  id                  String          @id @default(uuid())
  employerId          String
  employer            Employer        @relation(fields: [employerId], references: [id], onDelete: Cascade)
  candidateId         String
  candidate           Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId               String?
  job                 Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  
  // Inverse relation for application
  application         Application?    
  
  jobTitle            String?
  dateTime            DateTime
  duration            Int             @default(30) // minutes
  timezone            String          @default("UTC")
  type                InterviewType
  location            String
  meetingUrl          String?
  meetingRoomName     String?
  candidateMeetingUrl String?
  employerMeetingUrl  String?
  interviewerName     String?
  interviewerEmail    String?
  interviewers        Json?           // Array of { name: string, email: string }
  notes               String?         @db.Text
  feedback            String?         @db.Text
  rating              Int?
  recordingUrl        String?         // MinIO URL — set when recording is READY
  egressId            String?         // LiveKit Egress ID for active/completed recording
  recordingStatus     RecordingStatus @default(NONE)
  status              InterviewStatus @default(PENDING)
  cancelledAt              DateTime?
  cancelReason             String?
  mattermostChannelId      String?
  candidateArchivedAt      DateTime?   // set when candidate archives — auto-deleted after 30 days
  candidateRemovedAt       DateTime?   // set when candidate removes — hidden permanently
  employerArchivedAt       DateTime?   // set when employer archives — moves to Archive tab
  employerDeletedAt        DateTime?   // set when employer deletes — hidden permanently
  
  // Relations
  reminders           Reminder[]
  panelInvites        PanelInvite[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model PanelInvite {
  id          String    @id @default(uuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  name        String
  email       String
  token       String    @unique @default(uuid())
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Reminder {
  id          String        @id @default(uuid())
  interviewId String
  interview   Interview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  remindAt    DateTime
  type        ReminderType
  channel     ChannelType   @default(BOTH)
  sent        Boolean       @default(false)
  sentAt      DateTime?
  error       String?
}

model Offer {
  id            String      @id @default(uuid())
  candidateId   String
  candidate     Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  employerId    String
  employer      Employer    @relation(fields: [employerId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  // Inverse relation for Application
  application   Application?
  
  content       String      @db.Text
  status        OfferStatus @default(PENDING)
  salary        String
  currency      String      @default("NGN")
  startDate     DateTime
  token         String      @unique
  expiresAt     DateTime

  // EOR fields — set when employer requests payroll onboarding at hire
  eorRequested  Boolean     @default(false)
  eorStatus     String?     // "pending" | "active" | "terminated"
  eorContractId String?     // Frappe HR employee name e.g. "HR-EMP-00001"

  // Relations
  employmentRecord EmploymentRecord?
  signature        Signature?
  onboardingTasks  OnboardingTask[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model AptitudeTest {
  id             String     @id @default(uuid())
  title          String
  description    String?    @db.Text
  testType       TestType
  expertise      String?
  
  employerId     String?
  employer       Employer?  @relation("EmployerTests", fields: [employerId], references: [id])

  // Set on cloned (assigned) tests to track which candidate received it
  candidateId    String?
  candidate      Candidate? @relation("CandidateAssignedTests", fields: [candidateId], references: [id])

  originalTestId String?
  originalTest   AptitudeTest?  @relation("TestTemplate", fields: [originalTestId], references: [id])
  derivedTests   AptitudeTest[] @relation("TestTemplate")
  
  passingScore   Float      @default(70)
  timeLimit      Int?       // In minutes
  deadline       DateTime?  // Deadline for candidate to complete the assignment
  isActive       Boolean    @default(true)
  
  questions      Question[]
  results        TestResult[]
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Question {
  id            String       @id @default(uuid())
  testId        String
  test          AptitudeTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  question      String       @db.Text
  options       String[]
  correctAnswer String
  explanation   String?      @db.Text
}

model TestResult {
  id           String       @id @default(uuid())
  testId       String
  test         AptitudeTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  candidateId  String
  candidate    Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  employerId   String?
  employer     Employer?    @relation(fields: [employerId], references: [id], onDelete: SetNull)
  score        Float
  passingScore Float
  passed       Boolean
  timeSpent    Int?         // In seconds
  proctorStats Json?        // { noFaceCount, tabSwitchCount, multipleFaceCount, violations[] }
  completedAt  DateTime     @default(now())
  
  answers      Answer[]
  
  // Inverse relation for application
  application  Application?

  createdAt    DateTime     @default(now())
}

model Answer {
  id             String     @id @default(uuid())
  testResultId   String
  testResult     TestResult @relation(fields: [testResultId], references: [id], onDelete: Cascade)
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
}

model NotificationLog {
  id            String             @id @default(uuid())
  userType      RoleType
  
  employerId    String?
  employer      Employer?          @relation(fields: [employerId], references: [id])
  candidateId   String?
  candidate     Candidate?         @relation(fields: [candidateId], references: [id])
  
  email         String?
  type          String
  channel       NotificationChannel
  subject       String?
  content       String             @db.Text
  status        NotificationStatus @default(PENDING)
  sentAt        DateTime?
  error         String?
  referenceId   String?
  referenceType String?
  
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

// ─── Local Employer Post-Hire Models ─────────────────────────────────────────

model Signature {
  id           String   @id @default(uuid())
  offerId      String   @unique
  offer        Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  signedByName String
  signedAt     DateTime @default(now())
  ipAddress    String?
}

model OnboardingTask {
  id          String    @id @default(uuid())
  offerId     String
  offer       Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  task        String
  order       Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model PostHireLog {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          String      // "day1" | "day30" | "day90" | "month6"
  sentAt        DateTime    @default(now())

  @@unique([applicationId, type])
}

// ─── EOR / Payroll Models ─────────────────────────────────────────────────────

model EmploymentRecord {
  id                  String    @id @default(uuid())

  // Links
  offerId             String    @unique
  offer               Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  employerId          String
  employer            Employer  @relation(fields: [employerId], references: [id], onDelete: Cascade)
  candidateId         String
  candidate           Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Frappe HR
  frappeEmployeeName  String?   // e.g. "HR-EMP-00001" — assigned by Frappe on creation
  frappeCompany       String?

  // Employment details
  country             String    // ISO2 country code e.g. NG, KE
  payType             PayType   @default(SALARY)      // SALARY | HOURLY — determines payroll calculation path
  grossSalary         Float                           // used when payType = SALARY
  hourlyRate          Float?                          // used when payType = HOURLY (Phase 2: clocking system)
  currency            String
  payrollCycle        String    @default("monthly")  // "monthly" | "biweekly"
  startDate           DateTime
  endDate             DateTime?

  // Status
  status              EorStatus @default(PENDING)

  // Paystack disbursement
  lastDisbursementAt  DateTime?
  lastDisbursementRef String?

  payslips            Payslip[]
  attendanceSessions  AttendanceSession[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Payslip {
  id                  String           @id @default(uuid())
  employmentRecordId  String
  employmentRecord    EmploymentRecord @relation(fields: [employmentRecordId], references: [id], onDelete: Cascade)
  candidateId         String
  candidate           Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // Frappe reference
  frappeSlipName      String?   // e.g. "Salary Slip/00001"

  // Pay period
  periodMonth         Int       // 1-12
  periodYear          Int

  // Amounts
  grossPay            Float
  totalDeductions     Float
  netPay              Float
  currency            String

  // Breakdown stored as JSON array: [{ salary_component, amount }]
  components          Json?

  // PDF stored in S3
  pdfUrl              String?

  // Paystack transfer
  transferCode        String?   // Paystack transfer_code
  disbursedAt         DateTime?

  status              PayslipStatus @default(GENERATED)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([employmentRecordId, periodMonth, periodYear])
}

// Enums definition
enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum JobStatus {
  ACTIVE
  CLOSED
  DRAFT
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  TEST_SENT
  INTERVIEW_SCHEDULED
  OFFER_SENT
  HIRED
  REJECTED
}

enum UserType {
  EMPLOYER
  CANDIDATE
}

enum RoleType {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum InterviewType {
  VIRTUAL
  PHYSICAL
}

enum InterviewStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum ReminderType {
  DAY_BEFORE
  HOUR_BEFORE
  FIFTEEN_MINUTES
}

enum ChannelType {
  EMAIL
  PUSH
  BOTH
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum TestType {
  ONBOARDING
  EMPLOYER_CUSTOM
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  IN_APP
  MATTERMOST
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum EorStatus {
  PENDING       // offer accepted, EOR onboarding not yet started
  ONBOARDING    // Frappe employee record created, salary structure assigned
  ACTIVE        // first payroll run completed
  TERMINATED    // employment ended
}

enum PayslipStatus {
  GENERATED     // salary slip created in Frappe
  DISBURSED     // salary transferred via Paystack
  FAILED        // disbursement failed
}

enum PayType {
  SALARY        // fixed monthly/biweekly gross salary
  HOURLY        // rate × hours worked; requires clocking system (Phase 2)
}

enum RecordingStatus {
  NONE          // interview was not recorded
  RECORDING     // LiveKit Egress is actively recording
  PROCESSING    // egress stopped; LiveKit is finalising the file
  READY         // recording available at recordingUrl
  FAILED        // egress or upload error
}

// ─── Programmes ───────────────────────────────────────────────────────────────
//
// Architecture:
//   ProgrammeEnquiry   — captures register form submissions; reviewed by Jorbex admin
//   ProgrammePortal    — the approved institutional account (Gov / Uni / Corp)
//   ProgrammeUser      — portal managers/admins with their own login (separate from Employer/Candidate)
//   ProgrammeAccessCode — Jorbex-provisioned login codes for Government portals (no password auth)
//   Programme          — an individual scheme/cohort inside a portal
//   ProgrammeMember    — candidates enrolled in a programme
//   ProgrammeInviteCode — codes that let candidates join a specific programme
//   ProgrammeJob       — jobs attached to a programme

// ── Enquiry (from /programmes/register) ─────────────────────────────────────

model ProgrammeEnquiry {
  id              String         @id @default(uuid())
  type            ProgrammeType
  institutionName String
  country         String
  city            String?
  contactName     String?
  contactTitle    String?
  email           String
  phone           String?
  website         String?
  estimatedSize   String?
  notes           String?        @db.Text

  status          EnquiryStatus  @default(PENDING)
  reviewedAt      DateTime?
  reviewedBy      String?        // Admin.id who actioned it
  reviewNotes     String?        @db.Text

  // Set once Jorbex approves and creates the portal
  portalId        String?        @unique
  portal          ProgrammePortal? @relation(fields: [portalId], references: [id])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ── Portal (the institutional account) ──────────────────────────────────────

model ProgrammePortal {
  id              String              @id @default(uuid())
  type            ProgrammeType

  // Institution details
  institutionName String
  country         String
  city            String?
  website         String?
  slug            String              @unique  // e.g. "unilag", "shell-ng", "fmol-gov"

  // Branding
  logoUrl         String?
  bannerUrl       String?
  primaryColour   String              @default("#2563eb")
  welcomeMessage  String?             @db.Text

  // Billing
  billingModel    String              @default("FLAT")  // "FLAT" | "PER_SEAT" | "PER_PLACEMENT"
  billingAmount   Float?
  billingCurrency String              @default("NGN")
  subscriptionStatus PortalSubStatus  @default(TRIAL)
  subscriptionEndDate DateTime?

  status          PortalStatus        @default(PENDING)  // PENDING until Jorbex approves
  approvedAt      DateTime?
  approvedBy      String?             // Admin.id

  // Relations
  users           ProgrammeUser[]
  accessCodes     ProgrammeAccessCode[]
  programmes      Programme[]
  enquiry         ProgrammeEnquiry?   // originating enquiry (nullable — admin may create directly)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

// ── Portal Users (managers/admins for University & Corporate) ────────────────

model ProgrammeUser {
  id          String          @id @default(uuid())
  portalId    String
  portal      ProgrammePortal @relation(fields: [portalId], references: [id], onDelete: Cascade)

  name        String
  email       String          @unique
  password    String          // bcrypt hash; null only for Government (uses access codes instead)
  role        PortalUserRole  @default(MANAGER)

  isActive    Boolean         @default(true)
  lastLoginAt DateTime?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// ── Government Access Codes (provisioned by Jorbex admin) ───────────────────

model ProgrammeAccessCode {
  id          String          @id @default(uuid())
  portalId    String
  portal      ProgrammePortal @relation(fields: [portalId], references: [id], onDelete: Cascade)

  code        String          @unique
  label       String?         // e.g. "Director of Placement — Federal Ministry of Labour"
  isActive    Boolean         @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  usedCount   Int             @default(0)

  createdAt   DateTime        @default(now())
}

// ── Programme (a single scheme/cohort inside a portal) ───────────────────────

model Programme {
  id              String                @id @default(uuid())
  slug            String                @unique  // e.g. "nysc-2026-batch-a"
  name            String
  description     String?               @db.Text
  type            ProgrammeType

  // Owned by a portal, not an Employer
  portalId        String
  portal          ProgrammePortal       @relation(fields: [portalId], references: [id], onDelete: Cascade)

  // Programme details
  country         String?
  city            String?
  startDate       DateTime?
  endDate         DateTime?
  maxParticipants Int?

  // Access control
  inviteOnly      Boolean               @default(true)
  allowedDomains  String[]              // e.g. ["unilag.edu.ng"] restricts by email domain

  // Branding (inherits from portal, can override)
  logoUrl         String?
  bannerUrl       String?
  primaryColour   String?
  welcomeMessage  String?               @db.Text

  status          ProgrammeStatus       @default(DRAFT)

  // Relations
  members         ProgrammeMember[]
  inviteCodes     ProgrammeInviteCode[]
  programmeJobs   ProgrammeJob[]

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

// ── Programme Members (candidates enrolled in a programme) ───────────────────

model ProgrammeMember {
  id          String                @id @default(uuid())
  programmeId String
  programme   Programme             @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status      ProgrammeMemberStatus @default(ACTIVE)
  enrolledAt  DateTime              @default(now())
  completedAt DateTime?

  @@unique([programmeId, candidateId])
}

// ── Invite Codes (for candidates to join a programme) ────────────────────────

model ProgrammeInviteCode {
  id          String    @id @default(uuid())
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  code        String    @unique
  label       String?
  maxUses     Int?      // null = unlimited
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

// ── Programme Jobs (jobs attached to a programme) ────────────────────────────

model ProgrammeJob {
  id          String    @id @default(uuid())
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  addedAt     DateTime  @default(now())

  @@unique([programmeId, jobId])
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum ProgrammeType {
  GOVERNMENT
  UNIVERSITY
  CORPORATE
}

enum ProgrammeStatus {
  DRAFT
  ACTIVE
  COMPLETED
  SUSPENDED
}

enum ProgrammeMemberStatus {
  PENDING
  ACTIVE
  COMPLETED
  REMOVED
}

enum PortalStatus {
  PENDING     // awaiting Jorbex admin approval
  ACTIVE      // live and accessible
  SUSPENDED   // temporarily disabled
  REJECTED    // application declined
}

enum PortalSubStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PortalUserRole {
  OWNER       // institution's primary admin (created at approval)
  MANAGER     // can manage programmes and members
  VIEWER      // read-only reporting access
}

enum EnquiryStatus {
  PENDING     // submitted, not yet reviewed
  REVIEWING   // Jorbex team is reviewing
  APPROVED    // portal has been created
  REJECTED    // declined
  MORE_INFO   // team requested more information
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteContent {
  id        String   @id @default(uuid())
  section   String
  key       String
  value     String   @db.Text
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, key])
}

// ─── Identity Verification ────────────────────────────────────────────────────

model IdentityVerification {
  id          String             @id @default(uuid())
  candidateId String             @unique
  candidate   Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  docType     IdDocType          // PASSPORT | NATIONAL_ID
  docNumber   String?            // optional self-declared document number
  country     String             // issuing country

  fileUrl     String             // MinIO URL
  fileKey     String             // MinIO object key (for deletion/reference)

  status      VerificationStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewedBy  String?            // Admin.id
  reviewNotes String?            @db.Text

  submittedAt DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model CompanyVerification {
  id         String             @id @default(uuid())
  employerId String             @unique
  employer   Employer           @relation(fields: [employerId], references: [id], onDelete: Cascade)

  bizType    BizType            // REGISTERED | INFORMAL

  // Registered company fields
  regNumber  String?            // self-declared registration number
  regDocUrl  String?            // company registration certificate URL
  regDocKey  String?            // MinIO key

  // Informal business fields
  idDocType  IdDocType?         // PASSPORT | NATIONAL_ID
  idDocUrl   String?            // ID document URL
  idDocKey   String?
  bankName   String?            // bank name
  bankAccName String?           // account name (as it appears on bank records)
  bankStmtUrl String?           // bank statement URL
  bankStmtKey String?

  status      VerificationStatus @default(PENDING)
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNotes String?            @db.Text

  submittedAt DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IdDocType {
  PASSPORT
  NATIONAL_ID
}

enum BizType {
  REGISTERED
  INFORMAL
}

// ─── Jorbex Office (JO) Models ────────────────────────────────────────────────
// Milestone 1: The Foundation

model AttendanceSession {
  id                  String           @id @default(uuid())
  employmentRecordId  String
  employmentRecord    EmploymentRecord @relation(fields: [employmentRecordId], references: [id], onDelete: Cascade)
  
  clockIn             DateTime         @default(now())
  clockOut            DateTime?
  
  // Geolocation (Optional/Enterprise - Milestone 1: Basic IP logging)
  ipAddress           String?
  lat                 Float?
  lng                 Float?
  
  // Activity Metadata
  status              WorkStatus       @default(ACTIVE)
  totalActiveMinutes  Int              @default(0)
  totalIdleMinutes    Int              @default(0)
  
  overtimeMinutes     Int              @default(0)
  
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

enum WorkStatus {
  ACTIVE
  IDLE
  ON_BREAK
  OFFLINE
}
